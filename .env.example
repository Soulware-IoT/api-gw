# Supabase project (used to validate JWTs: issuer + JWKS).
SUPABASE_URL=https://<project-ref>.supabase.co

# Port the api-gw listens on.
PORT=3000

# Backend services. The cocina360 backend is a modular monolith, so every
# bounded-context URL points to the same host (default Spring Boot port 8080).
# Swap for the deployed backend URL in non-local environments.
ORGANIZATIONS_SERVICE_URL=http://localhost:8080
SECURITY_SERVICE_URL=http://localhost:8080
PROFILES_SERVICE_URL=http://localhost:8080
INTERNAL_CONTROL_SERVICE_URL=http://localhost:8080
