# Supabase project (used to validate JWTs: issuer + JWKS).
SUPABASE_URL=https://<project-ref>.supabase.co

# Cocina360 backend (modular monolith). The gateway forwards every bounded
# context to this single deployment URL. Swap for the deployed backend URL in
# non-local environments.
BACKEND_URL=http://localhost:8080

# Comma-separated list of allowed CORS origins. Required — app will not start without this.
ALLOWED_ORIGINS=http://localhost:4200,https://your-app.example.com
